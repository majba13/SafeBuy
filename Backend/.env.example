# ─── App ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
MOBILE_URL=exp://localhost:8081

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/safebuy?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Email (Nodemailer) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=SafeBuy <noreply@safebuy.com>

# ─── Cloudinary ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ─── Firebase (Push Notifications) ──────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Super Admin ─────────────────────────────────────────
SUPER_ADMIN_EMAIL=majbauddin.personal@gmail.com
SUPER_ADMIN_PASSWORD=SuperAdmin@SafeBuy2026!

# ─── Payment Numbers ─────────────────────────────────────
BKASH_NUMBER=01752962104
NAGAD_NUMBER=01752962104
ROCKET_NUMBER=01752962104
BANK_ACCOUNT=20501306700352701
BANK_ROUTING=125264097
BANK_NAME=Islami Bank Bangladesh Limited

# ─── Courier APIs ────────────────────────────────────────
PATHAO_CLIENT_ID=your_pathao_client_id
PATHAO_CLIENT_SECRET=your_pathao_client_secret
STEADFAST_API_KEY=your_steadfast_api_key
STEADFAST_API_SECRET=your_steadfast_api_secret
PATHAO_USERNAME=your_pathao_username
PATHAO_PASSWORD=your_pathao_password
PATHAO_STORE_ID=your_pathao_store_id
PAPERFLY_API_KEY=your_paperfly_api_key
PAPERFLY_TOKEN=your_paperfly_token
REDX_API_KEY=your_redx_api_key
REDX_PICKUP_STORE_ID=your_redx_pickup_store_id

# ─── AI / ML ────────────────────────────────────────────────────────────────
# Google Gemini 1.5 Flash (free tier — 15 RPM, 1M TPM)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key

# HuggingFace Inference API (chatbot fallback + text generation)
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key

